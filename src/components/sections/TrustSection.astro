---
const stats = [
  { num: 50,   suffix: '+', label: 'Clientes atendidos' },
  { num: 500,  suffix: '+', label: 'Consultas realizadas' },
  { num: 10,   suffix: '+', label: 'Años de experiencia' },
];
---

<section class="trust-section" id="nosotros" aria-labelledby="trust-heading">
  <div class="trust-inner">

    <!-- Mission Block -->
    <div class="mission-block reveal">
      <div class="mission-header">
        <div class="mission-label-group">
          <span class="section-label">Nuestra misión</span>
          <div class="section-divider" style="width: 2.5rem;"></div>
        </div>
        <a href="#servicios" class="mission-read-more">
          CONOCER MÁS
          <span class="mission-read-arrow">↗</span>
        </a>
      </div>

      <div class="mission-text-block">
        <p class="mission-text" id="trust-heading">
          <span class="mission-text-bold">Ayudamos a personas y empresas</span>
          <span class="mission-text-bold"> a tomar decisiones legales</span>
          <span class="mission-text-muted"> con claridad y respaldo profesional. Nuestro enfoque combina criterio jurídico sólido con atención cercana y comunicación clara,</span>
          <span class="mission-text-muted"> orientada a proteger lo que más importa.</span>
        </p>
      </div>
    </div>

    <!-- Stats Block -->
    <div class="stats-block">
      <div class="stats-label-group reveal">
        <span class="section-label">Por qué Veredicta</span>
      </div>

      <div class="stats-circles" id="stats-circles">
        <!-- Círculo 1 (izquierdo, pequeño, solo arco inferior) -->
        <div class="stat-circle stat-circle--0">
          <div class="stat-circle-inner">
            <span class="stat-value" data-target={stats[0].num} data-suffix={stats[0].suffix}>0{stats[0].suffix}</span>
            <span class="stat-label">{stats[0].label}</span>
          </div>
        </div>

        <!-- Círculo 2 (central, grande, completo) -->
        <div class="stat-circle stat-circle--1">
          <div class="stat-circle-inner">
            <span class="stat-value" data-target={stats[1].num} data-suffix={stats[1].suffix}>0{stats[1].suffix}</span>
            <span class="stat-label">{stats[1].label}</span>
          </div>
        </div>

        <!-- Círculo 3 (derecho, pequeño, solo arco superior) -->
        <div class="stat-circle stat-circle--2">
          <div class="stat-circle-inner">
            <span class="stat-value" data-target={stats[2].num} data-suffix={stats[2].suffix}>0{stats[2].suffix}</span>
            <span class="stat-label">{stats[2].label}</span>
          </div>
        </div>
      </div>

      <!-- Value props below stats -->
      <div class="trust-props">
        <div class="trust-prop reveal delay-100">
          <div class="trust-prop-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4"/>
              <path d="M21 12c0 1.2-.504 2.28-1.31 3.036C18.48 16.2 17.04 17 15.5 17c-.882 0-1.714-.22-2.44-.6a5.5 5.5 0 0 1-1.06 0C11.214 16.78 10.382 17 9.5 17c-1.54 0-2.98-.8-3.19-1.964A4.995 4.995 0 0 1 3 12c0-2.76 2.239-5 5-5 .879 0 1.713.217 2.44.594a5.502 5.502 0 0 1 1.06 0C12.287 7.217 13.121 7 14 7c2.761 0 5 2.24 5 5z"/>
            </svg>
          </div>
          <div>
            <h3 class="trust-prop-title">Atención directa con abogado</h3>
            <p class="trust-prop-desc">Cada caso es atendido de forma personalizada, sin intermediarios.</p>
          </div>
        </div>

        <div class="trust-prop reveal delay-200">
          <div class="trust-prop-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <div>
            <h3 class="trust-prop-title">Estrategia legal personalizada</h3>
            <p class="trust-prop-desc">Cada caso requiere un análisis único con enfoque a resultados.</p>
          </div>
        </div>

        <div class="trust-prop reveal delay-300">
          <div class="trust-prop-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <div>
            <h3 class="trust-prop-title">Comunicación clara y seguimiento</h3>
            <p class="trust-prop-desc">Mantenemos informado a cada cliente en cada etapa del proceso.</p>
          </div>
        </div>

        <div class="trust-prop reveal delay-400">
          <div class="trust-prop-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div>
            <h3 class="trust-prop-title">Confidencialidad y criterio profesional</h3>
            <p class="trust-prop-desc">Máxima discreción y respeto en el manejo de cada asunto.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .trust-section {
    padding: 1rem 1rem;
  }

  .trust-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Mission */
  .mission-block {
    background-color: white;
    border-radius: 1.5rem;
    padding: 3rem 2.5rem;
  }

  @media (max-width: 640px) {
    .mission-block {
      padding: 2rem 1.5rem;
    }
  }

  .mission-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .mission-label-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mission-read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-navy);
    text-decoration: none;
    opacity: 0.55;
    transition: opacity 0.2s ease;
  }

  .mission-read-more:hover {
    opacity: 1;
  }

  .mission-read-arrow {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    border: 1.5px solid var(--color-navy);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    transition: transform 0.2s ease;
  }

  .mission-read-more:hover .mission-read-arrow {
    transform: translate(2px, -2px);
  }

  .mission-text {
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    line-height: 1.35;
    letter-spacing: -0.01em;
    font-weight: 400;
  }

  .mission-text-bold {
    color: var(--color-navy);
    font-weight: 500;
  }

  .mission-text-muted {
    color: var(--color-muted);
    font-weight: 400;
  }

  /* Stats */
  .stats-block {
    background-color: white;
    border-radius: 1.5rem;
    padding: 3rem 2.5rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  @media (max-width: 640px) {
    .stats-block {
      padding: 2rem 1.5rem 2.5rem;
    }
  }

  .stats-label-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Circles */
  .stats-circles {
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    height: 420px;
  }

  .stat-circle {
    border-radius: 50%;
    border: 1px solid rgba(15, 32, 51, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background-color: transparent;
  }

  .stat-circle--0 {
    width: 280px;
    height: 280px;
    border-color: rgba(15, 32, 51, 0.15);
  }

  .stat-circle--1 {
    position: relative;
    width: 400px;
    height: 400px;
    border-color: rgba(61, 107, 138, 0.2);
  }

  .stat-circle--2 {
    width: 280px;
    height: 280px;
    border-color: rgba(15, 32, 51, 0.1);
  }

  .stat-circle--1::before, .stat-circle--1::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background-color: rgba(15, 32, 51);
    flex-shrink: 0;
    align-self: center;
  }

  .stat-circle--1::before {
    left: -0.35rem;
  }

  .stat-circle--1::after {
    right: -0.35rem;
  }

  @media (max-width: 640px) {
    .stats-circles {
      flex-direction: column;
      overflow: visible;
      height: auto;
      gap: 1.5rem;
    }

    .stat-circle--0,
    .stat-circle--1,
    .stat-circle--2 {
      width: 200px;
      height: 200px;
      transform: none;
    }

    .stat-circle--1::after, .stat-circle--1::before {
      display: none;
    }
  }

  .stat-circle-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
  }

  .stat-value {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 300;
    color: var(--color-navy);
    letter-spacing: -0.03em;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .stat-label {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-muted);
    line-height: 1.4;
    max-width: 10ch;
    text-align: center;
  }

  /* Trust props */
  .trust-props {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2rem;
  }

  @media (max-width: 600px) {
    .trust-props {
      grid-template-columns: 1fr;
    }
  }

  .trust-prop {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .trust-prop-icon {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.625rem;
    background-color: rgba(15, 32, 51, 0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-navy);
    margin-top: 0.1rem;
  }

  .trust-prop-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .trust-prop-desc {
    font-size: 0.8rem;
    color: var(--color-muted);
    line-height: 1.6;
  }
</style>

<script>
  function easeOutQuart(t: number): number {
    return 1 - Math.pow(1 - t, 4);
  }

  function animateCount(el: HTMLElement) {
    const target = parseInt(el.dataset.target ?? '0', 10);
    const suffix = el.dataset.suffix ?? '';
    const duration = 1800;
    const start = performance.now();

    function step(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const current = Math.round(easeOutQuart(progress) * target);
      el.textContent = current + suffix;
      if (progress < 1) requestAnimationFrame(step);
    }

    requestAnimationFrame(step);
  }

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll<HTMLElement>('[data-target]').forEach(animateCount);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });

  const container = document.getElementById('stats-circles');
  if (container) observer.observe(container);
</script>
