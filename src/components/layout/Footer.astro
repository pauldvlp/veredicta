---
const navLinks = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Testimonios', href: '#testimonios' },
  { label: 'Preguntas', href: '#preguntas' },
  { label: 'Contacto', href: '#contacto' },
];

const currentYear = new Date().getFullYear();
---

<footer class="site-footer" id="footer">
  <!-- Top CTA block -->
  <div class="footer-cta-block">
    <div class="footer-cta-inner">
      <div class="footer-cta-left">
        <h2 class="footer-cta-headline">
          Resolvamos tus
          <br />
          retos legales juntos.
        </h2>
        <a href="#contacto" class="footer-cta-btn">
          <span>HABLEMOS</span>
          <span class="footer-cta-btn-arrow">↗</span>
        </a>
      </div>

      <div class="footer-contact-info">
        <div class="footer-contact-block">
          <span class="footer-contact-label">Teléfono</span>
          <a href="tel:+50400000000" class="footer-contact-value">+504 0000 0000</a>
        </div>
        <div class="footer-contact-block">
          <span class="footer-contact-label">Correo</span>
          <a href="mailto:contacto@veredicta.hn" class="footer-contact-value">contacto@veredicta.hn</a>
        </div>
        <div class="footer-contact-block">
          <span class="footer-contact-label">Ubicación</span>
          <span class="footer-contact-value">Tegucigalpa, Honduras</span>
        </div>
        <div class="footer-contact-block">
          <span class="footer-contact-label">Horario</span>
          <span class="footer-contact-value">Lun–Vie · 9:00 – 18:00</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="footer-bottom-inner">
      <!-- Logo -->
      <a href="/" class="footer-logo" aria-label="Veredicta — Inicio">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3L3 9v2h18V9L12 3z"/>
          <path d="M5 11v8"/>
          <path d="M19 11v8"/>
          <path d="M3 19h18"/>
          <path d="M7 11v8"/>
          <path d="M17 11v8"/>
          <path d="M10 11v8"/>
          <path d="M14 11v8"/>
          <path d="M2 21h20"/>
        </svg>
        <span>VEREDICTA</span>
      </a>

      <!-- Nav links -->
      <nav class="footer-nav" aria-label="Navegación footer">
        {navLinks.map(link => (
          <a href={link.href} class="footer-nav-link">{link.label}</a>
        ))}
      </nav>

      <!-- Copyright -->
      <p class="footer-copyright">
        © {currentYear} Veredicta
      </p>
    </div>

    <!-- Legal disclaimer -->
    <div class="footer-disclaimer">
      <p>El envío de información a través de este sitio no constituye una relación abogado-cliente. La información publicada tiene fines informativos generales y no debe considerarse asesoría legal específica. Veredicta es una marca registrada. Todos los derechos reservados.</p>
      <div class="footer-legal-links">
        <a href="/privacidad">Política de privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="/aviso-legal">Aviso legal</a>
        <span aria-hidden="true">·</span>
        <a href="/cookies">Cookies</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-navy);
    color: white;
    margin: 1rem;
    border-radius: 1.5rem 1.5rem 0.75rem 0.75rem;
    overflow: hidden;
  }

  /* CTA Block */
  .footer-cta-block {
    padding: 4rem 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-cta-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .footer-cta-inner {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .footer-cta-left {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .footer-cta-headline {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: white;
    max-width: 480px;
  }

  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: white;
    text-decoration: none;
  }

  .footer-cta-btn-arrow {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .footer-cta-btn:hover .footer-cta-btn-arrow {
    transform: translate(2px, -2px);
    border-color: white;
  }

  /* Contact info */
  .footer-contact-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2.5rem;
  }

  @media (max-width: 480px) {
    .footer-contact-info {
      grid-template-columns: 1fr;
    }
  }

  .footer-contact-block {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .footer-contact-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }

  .footer-contact-value {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-contact-value:hover {
    color: white;
  }

  /* Bottom bar */
  .footer-bottom {
    padding: 1.75rem 2.5rem;
  }

  .footer-bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  @media (min-width: 768px) {
    .footer-bottom-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  /* Logo */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    flex-shrink: 0;
  }

  /* Footer nav */
  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
  }

  .footer-nav-link {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: 0.02em;
  }

  .footer-nav-link:hover {
    color: rgba(255, 255, 255, 0.85);
  }

  /* Copyright */
  .footer-copyright {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  /* Disclaimer */
  .footer-disclaimer {
    max-width: 1200px;
    margin: 1.25rem auto 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-disclaimer p {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.25);
    line-height: 1.7;
    max-width: 800px;
  }

  .footer-legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.2);
  }

  .footer-legal-links a {
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-legal-links a:hover {
    color: rgba(255, 255, 255, 0.65);
  }
</style>
