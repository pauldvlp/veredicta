---
interface Props {
  icon: string;
  title: string;
  description: string;
  isHighlighted?: boolean;
}

const { icon, title, description, isHighlighted = false } = Astro.props;
---

<div class:list={['advantage-card', { 'advantage-card--highlighted': isHighlighted }]}>
  <div class="advantage-card-icon" aria-hidden="true" set:html={icon}></div>
  <div class="advantage-card-body">
    <h3 class="advantage-card-title">{title}</h3>
    <p class="advantage-card-desc">{description}</p>
  </div>
</div>

<style>
  .advantage-card {
    flex: 0 0 280px;
    height: 100%;
    border-radius: 1.5rem;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background-color: var(--color-card);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    position: relative;
    overflow: hidden;
  }

  .advantage-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(15, 32, 51, 0.12);
  }

  .advantage-card--highlighted {
    background-color: #1e4d6b;
    color: white;
  }

  .advantage-card-icon {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    height: 1.75rem;
    flex-shrink: 0;
    color: var(--color-muted);
    opacity: 0.7;
  }

  .advantage-card--highlighted .advantage-card-icon {
    color: rgba(255, 255, 255, 0.5);
  }

  .advantage-card-icon :global(svg) {
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
  }

  .advantage-card-body {
    margin-top: auto;
    padding-top: 2rem;
  }

  .advantage-card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .advantage-card--highlighted .advantage-card-title {
    color: white;
  }

  .advantage-card-desc {
    font-size: 0.825rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .advantage-card--highlighted .advantage-card-desc {
    color: rgba(255, 255, 255, 0.65);
  }
</style>
